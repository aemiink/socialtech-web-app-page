{
  "name": "socialtech-server",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend foundation for Social Tech.",
  "license": "UNLICENSED",
  "packageManager": "npm@11.8.0",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "typecheck:seed": "tsc -p tsconfig.seed.json --noEmit",
    "typecheck:spec": "tsc -p tsconfig.spec.json --noEmit",
    "check": "npm run typecheck && npm run typecheck:seed && npm run typecheck:spec && npm run build",
    "test:e2e:prepare": "node ./test/run-e2e.cjs --prepare-only",
    "test:e2e": "node ./test/run-e2e.cjs",
    "test:e2e:authz": "node ./test/run-e2e.cjs authz",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.17.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "joi": "^18.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.7.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "prisma": "^6.17.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
