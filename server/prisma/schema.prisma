model ProjectFile {
  id               String                @id @default(uuid()) @db.Uuid
  projectId        String                @db.Uuid
  folderId         String?               @db.Uuid
  clientProfileId  String                @db.Uuid
  serviceKey       PurchasedServiceKey?
  category         ProjectFileCategory
  visibility       ProjectFileVisibility @default(INTERNAL)
  title            String
  description      String?
  publicId         String
  secureUrl        String
  resourceType     String                @default("raw")
  format           String?
  bytes            Int
  mimeType         String
  originalFileName String
  approvalRequired Boolean               @default(false)
  approvalType     MetaAdsApprovalType?
  approvalStatus   MetaAdsApprovalStatus?
  approvalResponseNote String?
