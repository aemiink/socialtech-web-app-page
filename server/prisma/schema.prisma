generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum UserRole {
  ADMIN
  PROJECT_MANAGER
  PERFORMANCE_SPECIALIST
  SOCIAL_MEDIA_SPECIALIST
  DESIGNER
  DEVELOPER
  SUPPORT_SPECIALIST
  SEO_SPECIALIST
  CLIENT_OWNER
  CLIENT_MEMBER
  CRM_SPECIALIST
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PurchasedServiceKey {
  GROWTH_HUB
  SOCIAL_MEDIA
  MEDIA_HUB
  META_ADS
  TIKTOK_ADS
  GOOGLE_ADS
  AMAZON_ADS
  WEB_APP
  MOBILE_APP
  LANDING_PAGE
  WEB_MOBILE_DESIGN
  TECHNICAL_SUPPORT
  SEO_AUDIT
}

enum PurchasedServiceStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum EmployeeClientAssignmentScope {
  PROJECT
  PERFORMANCE
  SOCIAL_MEDIA
  DESIGN
  DEVELOPMENT
  SUPPORT
  SEO
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  REVIEW
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskTodoVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum TaskType {
  FEATURE
  BUG
  REVISION
  QA
  DEPLOYMENT
  MAINTENANCE
}

enum TaskWorkstream {
  FRONTEND
  BACKEND
  FULLSTACK
  QA
  DEVOPS
  UI_INTEGRATION
}

enum TaskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum DeliverySprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DeliveryReleaseStatus {
  PLANNED
  TESTING
  READY
  DEPLOYED
  FAILED
  ROLLED_BACK
}

enum DeliveryReleaseApprovalStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum RepositoryProvider {
  GITHUB
}

enum ProjectFileVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum ProjectFileCategory {
  WEB_SOURCE
  WEB_BUILD
  MOBILE_SOURCE
  MOBILE_BUILD
  ADS_CREATIVE
  SEO_REPORT
  BRAND_ASSET
  DOCUMENT
  CONTRACT
  OTHER
}

enum WebAppWorkspaceTabKey {
  OVERVIEW
  TASKS
  DELIVERY
  FILES
  CONTENT
  MESSAGES
  REVISIONS
  REPORTS
  MEETINGS
}

enum WebAppWorkspaceContentItemType {
  TEXT
  LINK
  EMBED
  CHECKLIST
  METRIC
}

enum WebAppWorkspaceRevisionStatus {
  REQUESTED
  ACKNOWLEDGED
  IN_PROGRESS
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum WebAppWorkspaceMeetingRequestStatus {
  REQUESTED
  CONFIRMED
  DECLINED
  COMPLETED
  CANCELLED
}

enum CrmLeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  WON
  LOST
}

enum CrmLeadSource {
  MANUAL
  WEBSITE_FORM
  SERPAPI
}

enum CrmLeadActivityType {
  CALL
  EMAIL
  WHATSAPP
  NOTE
  STATUS_CHANGE
}

enum CrmLeadScanStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum CrmLeadScanTrigger {
  MANUAL
  CRON
}

enum CrmLeadWebsiteStatus {
  NO_WEBSITE
  FETCH_FAILED
  ANALYZED
}

enum ClientApprovalType {
  DESIGN_APPROVAL
  FILE_APPROVAL
  TASK_APPROVAL
  SPRINT_APPROVAL
  RELEASE_APPROVAL
  REVISION_APPROVAL
  MEETING_CONFIRMATION
  INFORMATION
  GENERAL_CONFIRMATION
}

enum ClientApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ACKNOWLEDGED
  CANCELLED
  EXPIRED
}

enum ClientApprovalEntityType {
  PROJECT
  TASK
  TASK_TODO
  SPRINT
  RELEASE
  PROJECT_FILE
  WORKSPACE_MESSAGE
  DESIGN_ASSET
  REVISION
  MEETING_REQUEST
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  role         UserRole
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([role])
  @@index([permissionId])
}

model User {
  id                   String      @id @default(uuid()) @db.Uuid
  email                String      @unique
  displayName          String?
  passwordHash         String
  accountType          AccountType
  role                 UserRole
  clientProfileId      String?     @db.Uuid
  status               UserStatus  @default(ACTIVE)
  sessionInvalidatedAt DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  refreshTokens             RefreshToken[]
  clientProfile             ClientProfile?             @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  employeeClientAssignments EmployeeClientAssignment[] @relation("EmployeeClientAssignments")
  assignedTasks             Task[]                     @relation("TaskAssignee")
  codePreparedTasks         Task[]                     @relation("TaskCodePreparedBy")
  completedTaskTodos        TaskTodo[]                 @relation("TaskTodoCompletedBy")
  taskWorkNotes             TaskWorkNote[]             @relation("TaskWorkNoteAuthor")
  uploadedProjectFiles      ProjectFile[]              @relation("ProjectFileUploadedBy")
  createdProjectFileFolders ProjectFileFolder[]        @relation("ProjectFileFolderCreatedBy")
  assignedProjectFileFolders ProjectFileFolderAssignment[] @relation("ProjectFileFolderAssignedUser")
  projectFileShareLinks     ProjectFileShareLink[]     @relation("ProjectFileShareLinkCreatedBy")
  createdWorkspaceSections  WebAppWorkspaceSection[]   @relation("WorkspaceSectionCreatedBy")
  workspaceMessages         WebAppWorkspaceMessage[]   @relation("WorkspaceMessageAuthor")
  requestedWorkspaceRevisions WebAppWorkspaceRevision[] @relation("WorkspaceRevisionRequestedBy")
  assignedWorkspaceRevisions WebAppWorkspaceRevision[] @relation("WorkspaceRevisionAssignedTo")
  workspaceRevisionTransitions WebAppWorkspaceRevisionTransition[] @relation("WorkspaceRevisionTransitionActor")
  createdWeeklyReports      WebAppWorkspaceWeeklyReport[] @relation("WorkspaceWeeklyReportAuthor")
  requestedMeetingRequests  WebAppWorkspaceMeetingRequest[] @relation("WorkspaceMeetingRequestedBy")
  respondedMeetingRequests  WebAppWorkspaceMeetingRequest[] @relation("WorkspaceMeetingRespondedBy")
  ownedCrmLeads             CrmLead[]                  @relation("CrmLeadOwner")
  crmLeadActivities         CrmLeadActivity[]          @relation("CrmLeadActivityActor")
  releaseApprovalActions    DeliveryRelease[]          @relation("DeliveryReleaseApprovalActor")
  triggeredCrmLeadScans     CrmLeadScanLog[]           @relation("CrmLeadScanTriggeredBy")
  requestedClientApprovals  ClientApprovalRequest[]    @relation("ClientApprovalRequestedBy")
  assignedClientApprovals   ClientApprovalRequest[]    @relation("ClientApprovalAssignedTo")
  respondedClientApprovals  ClientApprovalRequest[]    @relation("ClientApprovalRespondedBy")
  clientApprovalTransitions ClientApprovalTransition[] @relation("ClientApprovalTransitionActor")
  auditLogs                 AuditLog[]                 @relation("AuditActor")

  @@index([accountType, role])
  @@index([accountType, status])
  @@index([clientProfileId])
  @@index([status])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt])
}

model ClientProfile {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique
  companyName  String
  contactEmail String?
  status       ClientStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users               User[]
  employeeAssignments EmployeeClientAssignment[]
  purchasedServices   ClientPurchasedService[]
  projects            Project[]
  files               ProjectFile[]
  approvalRequests    ClientApprovalRequest[]
  convertedCrmLeads   CrmLead[]                  @relation("CrmLeadConvertedClient")

  @@index([status])
}

model ClientPurchasedService {
  id              String                 @id @default(uuid()) @db.Uuid
  clientProfileId String                 @db.Uuid
  serviceKey      PurchasedServiceKey
  status          PurchasedServiceStatus @default(ACTIVE)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, serviceKey])
  @@index([clientProfileId, status])
  @@index([serviceKey, status])
}

model Project {
  id              String               @id @default(uuid()) @db.Uuid
  clientProfileId String               @db.Uuid
  serviceKey      PurchasedServiceKey?
  repositoryUrl   String?
  name            String
  slug            String
  description     String?
  figmaProjectUrl String?
  status          ProjectStatus        @default(PLANNED)
  priority        Priority             @default(MEDIUM)
  startDate       DateTime?
  dueDate         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  clientProfile    ClientProfile      @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  tasks            Task[]
  deliverySprints  DeliverySprint[]
  deliveryReleases DeliveryRelease[]
  repository       ProjectRepository?
  files            ProjectFile[]
  fileFolders      ProjectFileFolder[]
  approvalRequests ClientApprovalRequest[]
  workspaceSections WebAppWorkspaceSection[]
  workspaceMessages WebAppWorkspaceMessage[]
  workspaceRevisions WebAppWorkspaceRevision[]
  workspaceWeeklyReports WebAppWorkspaceWeeklyReport[]
  workspaceMeetingRequests WebAppWorkspaceMeetingRequest[]

  @@unique([clientProfileId, slug])
  @@index([clientProfileId])
  @@index([serviceKey])
  @@index([status])
  @@index([priority])
}

model Task {
  id                   String           @id @default(uuid()) @db.Uuid
  projectId            String           @db.Uuid
  sprintId             String?          @db.Uuid
  title                String
  description          String?
  status               TaskStatus       @default(TODO)
  priority             Priority         @default(MEDIUM)
  type                 TaskType         @default(FEATURE)
  workstream           TaskWorkstream   @default(FULLSTACK)
  severity             TaskSeverity?
  environment          TaskEnvironment?
  affectedUrl          String?
  reproductionSteps    String?
  reportedBy           String?
  code                 String?
  branchName           String?
  codePreparationNotes String?
  codePreparedAt       DateTime?
  codePreparedByUserId String?          @db.Uuid
  assigneeUserId       String?          @db.Uuid
  dueDate              DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint         DeliverySprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee       User?           @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  codePreparedBy User?           @relation("TaskCodePreparedBy", fields: [codePreparedByUserId], references: [id], onDelete: SetNull)
  todos          TaskTodo[]
  workNotes      TaskWorkNote[]
  workspaceRevisions WebAppWorkspaceRevision[]

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeUserId])
  @@index([codePreparedByUserId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([workstream])
  @@index([severity])
  @@index([environment])
  @@index([code])
  @@index([branchName])
}

model DeliverySprint {
  id        String               @id @default(uuid()) @db.Uuid
  projectId String               @db.Uuid
  name      String
  goal      String?
  status    DeliverySprintStatus @default(PLANNED)
  startDate DateTime
  endDate   DateTime
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model DeliveryRelease {
  id                  String                        @id @default(uuid()) @db.Uuid
  projectId           String                        @db.Uuid
  title               String
  environment         TaskEnvironment
  status              DeliveryReleaseStatus         @default(PLANNED)
  approvalStatus      DeliveryReleaseApprovalStatus @default(NOT_REQUESTED)
  version             String?
  releaseNotes        String?
  approvalNotes       String?
  scheduledAt         DateTime?
  deployedAt          DateTime?
  approvalRequestedAt DateTime?
  approvalRespondedAt DateTime?
  approvalActorUserId String?                       @db.Uuid
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvalActor User?   @relation("DeliveryReleaseApprovalActor", fields: [approvalActorUserId], references: [id], onDelete: SetNull)
  workspaceRevisions WebAppWorkspaceRevision[]

  @@index([projectId])
  @@index([status])
  @@index([approvalStatus])
  @@index([environment])
  @@index([scheduledAt])
  @@index([deployedAt])
  @@index([approvalActorUserId])
}

model ProjectRepository {
  id              String             @id @default(uuid()) @db.Uuid
  projectId       String             @unique @db.Uuid
  provider        RepositoryProvider @default(GITHUB)
  owner           String
  repo            String
  repositoryUrl   String
  defaultBranch   String?
  accessTokenEnc  String?
  accessTokenHash String?
  installationId  String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([owner, repo])
  @@index([isActive])
}

model ProjectFile {
  id               String                @id @default(uuid()) @db.Uuid
  projectId        String                @db.Uuid
  folderId         String?               @db.Uuid
  clientProfileId  String                @db.Uuid
  serviceKey       PurchasedServiceKey?
  category         ProjectFileCategory
  visibility       ProjectFileVisibility @default(INTERNAL)
  title            String
  description      String?
  publicId         String
  secureUrl        String
  resourceType     String                @default("raw")
  format           String?
  bytes            Int
  mimeType         String
  originalFileName String
  uploadedByUserId String                @db.Uuid
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  project    Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder     ProjectFileFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  clientProfile ClientProfile       @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  uploader   User                   @relation("ProjectFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  shareLinks ProjectFileShareLink[]
  workspaceRevisions WebAppWorkspaceRevision[]

  @@index([projectId, createdAt])
  @@index([projectId, folderId, createdAt])
  @@index([folderId])
  @@index([clientProfileId, createdAt])
  @@index([serviceKey])
  @@index([category])
  @@index([visibility])
  @@index([uploadedByUserId])
  @@unique([projectId, publicId])
}

model ProjectFileFolder {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @db.Uuid
  name            String
  createdByUserId String   @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User          @relation("ProjectFileFolderCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  files     ProjectFile[]
  assignees ProjectFileFolderAssignment[]

  @@unique([projectId, name])
  @@index([projectId, createdAt])
  @@index([createdByUserId])
}

model ProjectFileFolderAssignment {
  id             String   @id @default(uuid()) @db.Uuid
  folderId       String   @db.Uuid
  assignedUserId String   @db.Uuid
  createdAt      DateTime @default(now())

  folder       ProjectFileFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  assignedUser User              @relation("ProjectFileFolderAssignedUser", fields: [assignedUserId], references: [id], onDelete: Cascade)

  @@unique([folderId, assignedUserId])
  @@index([assignedUserId])
  @@index([folderId, createdAt])
}

model ProjectFileShareLink {
  id              String   @id @default(uuid()) @db.Uuid
  projectFileId   String   @db.Uuid
  tokenHash       String   @unique
  expiresAt       DateTime
  createdByUserId String   @db.Uuid
  isRevoked       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projectFile ProjectFile @relation(fields: [projectFileId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ProjectFileShareLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([projectFileId, createdAt])
  @@index([expiresAt])
  @@index([isRevoked])
  @@index([createdByUserId, createdAt])
}

model WebAppWorkspaceSection {
  id              String                   @id @default(uuid()) @db.Uuid
  projectId       String                   @db.Uuid
  tabKey          WebAppWorkspaceTabKey
  key             String
  title           String
  description     String?
  sortOrder       Int                      @default(0)
  createdByUserId String                   @db.Uuid
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  project   Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User                         @relation("WorkspaceSectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items     WebAppWorkspaceContentItem[]

  @@unique([projectId, tabKey, key])
  @@index([projectId, tabKey, sortOrder])
  @@index([createdByUserId])
}

model WebAppWorkspaceContentItem {
  id          String                         @id @default(uuid()) @db.Uuid
  sectionId   String                         @db.Uuid
  itemType    WebAppWorkspaceContentItemType
  title       String
  body        String?
  href        String?
  sortOrder   Int                            @default(0)
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt

  section WebAppWorkspaceSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, sortOrder])
  @@index([itemType])
}

model WebAppWorkspaceMessage {
  id           String                  @id @default(uuid()) @db.Uuid
  projectId    String                  @db.Uuid
  parentMessageId String?              @db.Uuid
  tabKey       WebAppWorkspaceTabKey
  authorUserId String                  @db.Uuid
  body         String
  isInternal   Boolean                 @default(false)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation("WorkspaceMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  parentMessage WebAppWorkspaceMessage? @relation("WorkspaceMessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       WebAppWorkspaceMessage[] @relation("WorkspaceMessageReplies")

  @@index([projectId, tabKey, createdAt])
  @@index([authorUserId, createdAt])
  @@index([parentMessageId, createdAt])
}

model WebAppWorkspaceRevision {
  id               String                        @id @default(uuid()) @db.Uuid
  projectId        String                        @db.Uuid
  taskId           String?                       @db.Uuid
  releaseId        String?                       @db.Uuid
  projectFileId    String?                       @db.Uuid
  title            String
  description      String
  requestedByUserId String                       @db.Uuid
  assignedToUserId String?                       @db.Uuid
  status           WebAppWorkspaceRevisionStatus @default(REQUESTED)
  requestedAt      DateTime                      @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  project     Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?                         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  release     DeliveryRelease?              @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  projectFile ProjectFile?                  @relation(fields: [projectFileId], references: [id], onDelete: SetNull)
  requestedBy User                          @relation("WorkspaceRevisionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  assignedTo  User?                         @relation("WorkspaceRevisionAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  transitions WebAppWorkspaceRevisionTransition[]

  @@index([projectId, status, requestedAt])
  @@index([taskId])
  @@index([releaseId])
  @@index([projectFileId])
  @@index([requestedByUserId, requestedAt])
  @@index([assignedToUserId, status])
}

model WebAppWorkspaceRevisionTransition {
  id          String                        @id @default(uuid()) @db.Uuid
  revisionId  String                        @db.Uuid
  fromStatus  WebAppWorkspaceRevisionStatus?
  toStatus    WebAppWorkspaceRevisionStatus
  actorUserId String                        @db.Uuid
  note        String?
  createdAt   DateTime                      @default(now())

  revision WebAppWorkspaceRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  actor    User                    @relation("WorkspaceRevisionTransitionActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([revisionId, createdAt])
  @@index([actorUserId, createdAt])
}

model WebAppWorkspaceWeeklyReport {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @db.Uuid
  weekStartDate  DateTime
  weekEndDate    DateTime
  summary        String
  accomplishments String?
  plannedNext    String?
  blockers       String?
  authorUserId   String   @db.Uuid
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation("WorkspaceWeeklyReportAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@unique([projectId, weekStartDate])
  @@index([projectId, weekEndDate])
  @@index([authorUserId, weekStartDate])
}

model WebAppWorkspaceMeetingRequest {
  id                String                             @id @default(uuid()) @db.Uuid
  projectId         String                             @db.Uuid
  title             String
  agenda            String?
  requestedByUserId String                             @db.Uuid
  preferredStartAt  DateTime
  preferredEndAt    DateTime
  timezone          String
  status            WebAppWorkspaceMeetingRequestStatus @default(REQUESTED)
  responseNote      String?
  responderUserId   String?                            @db.Uuid
  scheduledStartAt  DateTime?
  scheduledEndAt    DateTime?
  createdAt         DateTime                           @default(now())
  updatedAt         DateTime                           @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User    @relation("WorkspaceMeetingRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  responder   User?   @relation("WorkspaceMeetingRespondedBy", fields: [responderUserId], references: [id], onDelete: SetNull)

  @@index([projectId, status, preferredStartAt])
  @@index([requestedByUserId, createdAt])
  @@index([responderUserId, updatedAt])
}

model TaskTodo {
  id                String             @id @default(uuid()) @db.Uuid
  taskId            String             @db.Uuid
  title             String
  description       String?
  visibility        TaskTodoVisibility @default(INTERNAL)
  sortOrder         Int                @default(0)
  isCompleted       Boolean            @default(false)
  completedAt       DateTime?
  completedByUserId String?            @db.Uuid
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  task        Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy User? @relation("TaskTodoCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([taskId, visibility])
  @@index([taskId, isCompleted])
  @@index([taskId, sortOrder])
  @@index([completedByUserId])
}

model TaskWorkNote {
  id           String   @id @default(uuid()) @db.Uuid
  taskId       String   @db.Uuid
  authorUserId String   @db.Uuid
  note         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("TaskWorkNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([authorUserId, createdAt])
}

model CrmLead {
  id                       String                @id @default(uuid()) @db.Uuid
  companyName              String
  contactName              String
  contactEmail             String?
  phone                    String?
  source                   CrmLeadSource         @default(MANUAL)
  status                   CrmLeadStatus         @default(NEW)
  priority                 Priority?
  ownerUserId              String                @db.Uuid
  convertedClientProfileId String?               @db.Uuid
  address                  String?
  city                     String?
  sector                   String?
  website                  String?
  websiteStatus            CrmLeadWebsiteStatus?
  websiteIssues            Json?
  detectedPainPoints       Json?
  recommendedServices      Json?
  outreachAngle            String?
  emailSubject             String?
  emailBody                String?
  whatsappMessage          String?
  sourceQuery              String?
  sourceProvider           String?
  googleMapsUrl            String?
  googleRating             Float?
  reviewCount              Int?
  instagramUrl             String?
  whatsappPhone            String?
  leadScore                Int?
  nextFollowUpAt           DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  ownerUser              User              @relation("CrmLeadOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  convertedClientProfile ClientProfile?    @relation("CrmLeadConvertedClient", fields: [convertedClientProfileId], references: [id], onDelete: SetNull)
  activities             CrmLeadActivity[]

  @@index([ownerUserId])
  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([nextFollowUpAt])
  @@index([convertedClientProfileId])
  @@index([city])
  @@index([phone])
  @@index([website])
  @@index([googleMapsUrl])
  @@index([companyName, city])
  @@index([createdAt])
}

model CrmLeadActivity {
  id             String              @id @default(uuid()) @db.Uuid
  leadId         String              @db.Uuid
  actorUserId    String?             @db.Uuid
  type           CrmLeadActivityType
  note           String
  nextFollowUpAt DateTime?
  createdAt      DateTime            @default(now())

  lead  CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User?   @relation("CrmLeadActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([actorUserId])
  @@index([type])
  @@index([createdAt])
  @@index([nextFollowUpAt])
}

model CrmLeadScanLog {
  id                     String             @id @default(uuid()) @db.Uuid
  startedAt              DateTime           @default(now())
  finishedAt             DateTime?
  status                 CrmLeadScanStatus  @default(RUNNING)
  triggeredBy            CrmLeadScanTrigger @default(MANUAL)
  triggeredByUserId      String?            @db.Uuid
  totalQueriesUsed       Int                @default(0)
  totalBusinessesFetched Int                @default(0)
  totalDuplicates        Int                @default(0)
  totalWebsitesAnalyzed  Int                @default(0)
  totalQualified         Int                @default(0)
  totalSaved             Int                @default(0)
  totalFailed            Int                @default(0)
  queries                Json?
  errors                 Json?
  summary                String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  triggeredByUser User? @relation("CrmLeadScanTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([triggeredBy])
  @@index([triggeredByUserId])
  @@index([startedAt])
  @@index([createdAt])
}

model ClientApprovalRequest {
  id                      String                @id @default(uuid()) @db.Uuid
  clientProfileId         String                @db.Uuid
  projectId               String?               @db.Uuid
  serviceKey              PurchasedServiceKey?
  requestedByUserId       String?               @db.Uuid
  assignedToUserId        String?               @db.Uuid
  respondedByUserId       String?               @db.Uuid
  type                    ClientApprovalType
  status                  ClientApprovalStatus  @default(PENDING)
  title                   String
  message                 String
  entityType              ClientApprovalEntityType?
  entityId                String?
  actionPayload           Json?
  requiresExplicitApproval Boolean              @default(true)
  clientResponseNote      String?
  respondedAt             DateTime?
  dueAt                   DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  clientProfile ClientProfile               @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  project       Project?                    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requestedBy   User?                       @relation("ClientApprovalRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  assignedTo    User?                       @relation("ClientApprovalAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  respondedBy   User?                       @relation("ClientApprovalRespondedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)
  transitions   ClientApprovalTransition[]

  @@index([clientProfileId])
  @@index([projectId])
  @@index([serviceKey])
  @@index([status])
  @@index([type])
  @@index([entityType, entityId])
  @@index([requestedByUserId])
  @@index([assignedToUserId])
  @@index([respondedByUserId])
  @@index([createdAt])
  @@index([dueAt])
}

model ClientApprovalTransition {
  id          String               @id @default(uuid()) @db.Uuid
  approvalId  String               @db.Uuid
  actorUserId String               @db.Uuid
  fromStatus  ClientApprovalStatus?
  toStatus    ClientApprovalStatus
  note        String?
  createdAt   DateTime             @default(now())

  approval ClientApprovalRequest @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  actor    User                  @relation("ClientApprovalTransitionActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([approvalId, createdAt])
  @@index([actorUserId, createdAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model EmployeeClientAssignment {
  id              String                        @id @default(uuid()) @db.Uuid
  employeeUserId  String                        @db.Uuid
  clientProfileId String                        @db.Uuid
  scope           EmployeeClientAssignmentScope
  isActive        Boolean                       @default(true)
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt

  employeeUser  User          @relation("EmployeeClientAssignments", fields: [employeeUserId], references: [id], onDelete: Cascade)
  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([employeeUserId, clientProfileId, scope])
  @@index([employeeUserId, isActive])
  @@index([clientProfileId, isActive])
  @@index([scope, isActive])
}
