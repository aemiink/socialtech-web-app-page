  @@index([category])
  @@index([visibility])
  @@index([approvalRequired])
  @@index([approvalType])
  @@index([approvalStatus])
  @@index([approvalRespondedByUserId])
  @@index([uploadedByUserId])
  @@unique([projectId, publicId])
}

