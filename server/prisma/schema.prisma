generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum UserRole {
  ADMIN
  PROJECT_MANAGER
  PERFORMANCE_SPECIALIST
  SOCIAL_MEDIA_SPECIALIST
  DESIGNER
  DEVELOPER
  SUPPORT_SPECIALIST
  SEO_SPECIALIST
  CLIENT_OWNER
  CLIENT_MEMBER
  CRM_SPECIALIST
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PurchasedServiceKey {
  GROWTH_HUB
  SOCIAL_MEDIA
  MEDIA_HUB
  META_ADS
  TIKTOK_ADS
  GOOGLE_ADS
  AMAZON_ADS
  WEB_APP
  MOBILE_APP
  LANDING_PAGE
  WEB_MOBILE_DESIGN
  TECHNICAL_SUPPORT
  SEO_AUDIT
}

enum PurchasedServiceStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

enum MetaAdsConnectionStatus {
  NOT_CONNECTED
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum MetaAdsInsightLevel {
  ACCOUNT
  CAMPAIGN
  ADSET
  AD
}

enum MetaAdsSyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

enum TikTokAdsConnectionStatus {
  NOT_CONNECTED
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum AmazonAdsConnectionStatus {
  NOT_CONNECTED
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

enum AmazonAdsRegion {
  NA
  EU
  FE
}

enum TikTokAdsInsightLevel {
  ACCOUNT
  CAMPAIGN
  ADGROUP
  AD
}

enum TikTokAdsSyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

enum TikTokAdsReportType {
  WEEKLY
  MONTHLY
  CAMPAIGN_PERFORMANCE
  CREATIVE_PERFORMANCE
  BUDGET_RECOMMENDATION
}

enum TikTokAdsReportStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MetaAdsReportType {
  WEEKLY
  MONTHLY
  CAMPAIGN_PERFORMANCE
  CREATIVE_PERFORMANCE
  BUDGET_RECOMMENDATION
}

enum MetaAdsReportStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EmployeeClientAssignmentScope {
  PROJECT
  PERFORMANCE
  SOCIAL_MEDIA
  DESIGN
  DEVELOPMENT
  SUPPORT
  SEO
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  REVIEW
  COMPLETED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskTodoVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum TaskType {
  FEATURE
  BUG
  REVISION
  QA
  DEPLOYMENT
  MAINTENANCE
}

enum TaskWorkstream {
  FRONTEND
  BACKEND
  FULLSTACK
  QA
  DEVOPS
  UI_INTEGRATION
}

enum TaskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum MetaAdsApprovalType {
  META_ADS_CAMPAIGN_APPROVAL
  META_ADS_CREATIVE_APPROVAL
  META_ADS_BUDGET_CHANGE_APPROVAL
  META_ADS_REPORT_ACKNOWLEDGEMENT
  META_ADS_STRATEGY_APPROVAL
  TIKTOK_ADS_CAMPAIGN_APPROVAL
  TIKTOK_ADS_VIDEO_CREATIVE_APPROVAL
  TIKTOK_ADS_HOOK_TEST_APPROVAL
  TIKTOK_ADS_UGC_SCRIPT_APPROVAL
  TIKTOK_ADS_BUDGET_CHANGE_APPROVAL
  TIKTOK_ADS_REPORT_ACKNOWLEDGEMENT
}

enum MetaAdsApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
  ACKNOWLEDGED
}

enum DeliverySprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DeliveryReleaseStatus {
  PLANNED
  TESTING
  READY
  DEPLOYED
  FAILED
  ROLLED_BACK
}

enum DeliveryReleaseApprovalStatus {
  NOT_REQUESTED
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum RepositoryProvider {
  GITHUB
}

enum ProjectFileVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum ProjectFileCategory {
  WEB_SOURCE
  WEB_BUILD
  MOBILE_SOURCE
  MOBILE_BUILD
  ADS_CREATIVE
  SEO_REPORT
  BRAND_ASSET
  DOCUMENT
  CONTRACT
  OTHER
}

enum WebAppWorkspaceTabKey {
  OVERVIEW
  TASKS
  DELIVERY
  FILES
  CONTENT
  MESSAGES
  REVISIONS
  REPORTS
  MEETINGS
}

enum WebAppWorkspaceContentItemType {
  TEXT
  LINK
  EMBED
  CHECKLIST
  METRIC
}

enum WebAppWorkspaceRevisionStatus {
  REQUESTED
  ACKNOWLEDGED
  IN_PROGRESS
  READY_FOR_REVIEW
  APPROVED
  REJECTED
  CANCELLED
}

enum WebAppWorkspaceMeetingRequestStatus {
  REQUESTED
  CONFIRMED
  DECLINED
  COMPLETED
  CANCELLED
}

enum CrmLeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  WON
  LOST
}

enum CrmLeadSource {
  MANUAL
  WEBSITE_FORM
  SERPAPI
}

enum CrmLeadActivityType {
  CALL
  EMAIL
  WHATSAPP
  NOTE
  STATUS_CHANGE
}

enum CrmLeadScanStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum CrmLeadScanTrigger {
  MANUAL
  CRON
}

enum CrmLeadWebsiteStatus {
  NO_WEBSITE
  FETCH_FAILED
  ANALYZED
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  role         UserRole
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([role])
  @@index([permissionId])
}

model User {
  id                   String      @id @default(uuid()) @db.Uuid
  email                String      @unique
  displayName          String?
  passwordHash         String
  accountType          AccountType
  role                 UserRole
  clientProfileId      String?     @db.Uuid
  status               UserStatus  @default(ACTIVE)
  sessionInvalidatedAt DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  refreshTokens             RefreshToken[]
  clientProfile             ClientProfile?             @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  employeeClientAssignments EmployeeClientAssignment[] @relation("EmployeeClientAssignments")
  assignedTasks             Task[]                     @relation("TaskAssignee")
  codePreparedTasks         Task[]                     @relation("TaskCodePreparedBy")
  taskApprovalActions       Task[]                     @relation("TaskApprovalResponder")
  completedTaskTodos        TaskTodo[]                 @relation("TaskTodoCompletedBy")
  taskWorkNotes             TaskWorkNote[]             @relation("TaskWorkNoteAuthor")
  uploadedProjectFiles      ProjectFile[]              @relation("ProjectFileUploadedBy")
  projectFileApprovalActions ProjectFile[]             @relation("ProjectFileApprovalResponder")
  createdProjectFileFolders ProjectFileFolder[]        @relation("ProjectFileFolderCreatedBy")
  assignedProjectFileFolders ProjectFileFolderAssignment[] @relation("ProjectFileFolderAssignedUser")
  projectFileShareLinks     ProjectFileShareLink[]     @relation("ProjectFileShareLinkCreatedBy")
  createdWorkspaceSections  WebAppWorkspaceSection[]   @relation("WorkspaceSectionCreatedBy")
  workspaceMessages         WebAppWorkspaceMessage[]   @relation("WorkspaceMessageAuthor")
  requestedWorkspaceRevisions WebAppWorkspaceRevision[] @relation("WorkspaceRevisionRequestedBy")
  assignedWorkspaceRevisions WebAppWorkspaceRevision[] @relation("WorkspaceRevisionAssignedTo")
  workspaceRevisionTransitions WebAppWorkspaceRevisionTransition[] @relation("WorkspaceRevisionTransitionActor")
  createdWeeklyReports      WebAppWorkspaceWeeklyReport[] @relation("WorkspaceWeeklyReportAuthor")
  requestedMeetingRequests  WebAppWorkspaceMeetingRequest[] @relation("WorkspaceMeetingRequestedBy")
  respondedMeetingRequests  WebAppWorkspaceMeetingRequest[] @relation("WorkspaceMeetingRespondedBy")
  ownedCrmLeads             CrmLead[]                  @relation("CrmLeadOwner")
  crmLeadActivities         CrmLeadActivity[]          @relation("CrmLeadActivityActor")
  releaseApprovalActions    DeliveryRelease[]          @relation("DeliveryReleaseApprovalActor")
  triggeredCrmLeadScans     CrmLeadScanLog[]           @relation("CrmLeadScanTriggeredBy")
  auditLogs                 AuditLog[]                 @relation("AuditActor")
  createdMetaAdsReports     MetaAdsReport[]            @relation("MetaAdsReportCreatedBy")
  publishedMetaAdsReports   MetaAdsReport[]            @relation("MetaAdsReportPublishedBy")
  acknowledgedMetaAdsReports MetaAdsReport[]           @relation("MetaAdsReportAcknowledgedBy")
  createdTikTokAdsReports     TikTokAdsReport[]        @relation("TikTokAdsReportCreatedBy")
  publishedTikTokAdsReports   TikTokAdsReport[]        @relation("TikTokAdsReportPublishedBy")
  acknowledgedTikTokAdsReports TikTokAdsReport[]       @relation("TikTokAdsReportAcknowledgedBy")

  @@index([accountType, role])
  @@index([accountType, status])
  @@index([clientProfileId])
  @@index([status])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt])
}

model ClientProfile {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique
  companyName  String
  contactEmail String?
  status       ClientStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users               User[]
  employeeAssignments EmployeeClientAssignment[]
  purchasedServices   ClientPurchasedService[]
  metaAdsConfig       ClientMetaAdsConfig?
  metaAdsCredential   ClientMetaAdsCredential?
  metaAdsInsights     MetaAdsDailyInsight[]
  metaAdsSyncLogs     MetaAdsSyncLog[]
  metaAdsReports      MetaAdsReport[]
  tikTokAdsConfig     ClientTikTokAdsConfig?
  tikTokAdsCredential ClientTikTokAdsCredential?
  tikTokAdsInsights   TikTokAdsDailyInsight[]
  tikTokAdsSyncLogs   TikTokAdsSyncLog[]
  tikTokAdsReports    TikTokAdsReport[]
  amazonAdsConfig     ClientAmazonAdsConfig?
  amazonAdsCredential ClientAmazonAdsCredential?
  projects            Project[]
  files               ProjectFile[]
  convertedCrmLeads   CrmLead[]                  @relation("CrmLeadConvertedClient")

  @@index([status])
}

model ClientMetaAdsConfig {
  id                 String                  @id @default(uuid()) @db.Uuid
  clientProfileId    String                  @unique @db.Uuid
  businessId         String?
  adAccountId        String?
  pixelId            String?
  instagramAccountId String?
  facebookPageId     String?
  currency           String?
  timezone           String?
  connectionStatus   MetaAdsConnectionStatus @default(NOT_CONNECTED)
  lastSyncAt         DateTime?
  syncError          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([connectionStatus])
  @@index([lastSyncAt])
}

model ClientMetaAdsCredential {
  id              String    @id @default(uuid()) @db.Uuid
  clientProfileId String    @unique @db.Uuid
  accessTokenEnc  String?
  tokenHash       String?
  tokenExpiresAt  DateTime?
  grantedScopes   String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([tokenExpiresAt])
}

model ClientAmazonAdsConfig {
  id                  String                    @id @default(uuid()) @db.Uuid
  clientProfileId     String                    @unique @db.Uuid
  profileId           String?
  advertiserAccountId String?
  marketplaceId       String?
  region              AmazonAdsRegion?
  countryCode         String?
  currencyCode        String?
  timezone            String?
  accountType         String?
  accountName         String?
  validPaymentMethod  Boolean?
  connectionStatus    AmazonAdsConnectionStatus @default(NOT_CONNECTED)
  lastSyncAt          DateTime?
  syncError           String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([connectionStatus])
  @@index([lastSyncAt])
  @@index([region])
  @@index([marketplaceId])
}

model ClientAmazonAdsCredential {
  id                    String    @id @default(uuid()) @db.Uuid
  clientProfileId       String    @unique @db.Uuid
  accessTokenEnc        String?
  refreshTokenEnc       String?
  tokenHash             String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  grantedScopes         String[]  @default([])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([accessTokenExpiresAt])
  @@index([refreshTokenExpiresAt])
}

model MetaAdsDailyInsight {
  id             String               @id @default(uuid()) @db.Uuid
  clientProfileId String              @db.Uuid
  adAccountId    String
  date           DateTime
  level          MetaAdsInsightLevel
  entityId       String?
  entityName     String?
  spend          Decimal?
  impressions    Int?
  reach          Int?
  clicks         Int?
  ctr            Decimal?
  cpc            Decimal?
  cpm            Decimal?
  frequency      Decimal?
  results        Int?
  costPerResult  Decimal?
  purchaseValue  Decimal?
  roas           Decimal?
  raw            Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId, date])
  @@index([clientProfileId, level, date])
  @@index([clientProfileId, adAccountId, level, date])
  @@index([adAccountId, date])
}

model MetaAdsSyncLog {
  id              String            @id @default(uuid()) @db.Uuid
  clientProfileId String            @db.Uuid
  adAccountId     String?
  status          MetaAdsSyncStatus
  startedAt       DateTime
  finishedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  recordsFetched  Int?
  apiCallCount    Int?
  createdAt       DateTime          @default(now())

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId, createdAt])
  @@index([status, createdAt])
  @@index([clientProfileId, status, createdAt])
}

model MetaAdsReport {
  id                        String               @id @default(uuid()) @db.Uuid
  clientProfileId           String               @db.Uuid
  projectId                 String?              @db.Uuid
  periodStart               DateTime
  periodEnd                 DateTime
  type                      MetaAdsReportType
  status                    MetaAdsReportStatus  @default(DRAFT)
  summary                   String?
  metricsSnapshot           Json?
  createdByUserId           String?              @db.Uuid
  publishedByUserId         String?              @db.Uuid
  clientVisible             Boolean              @default(false)
  publishedAt               DateTime?
  acknowledgementRequestedAt DateTime?
  acknowledgedAt            DateTime?
  acknowledgedByUserId      String?              @db.Uuid
  acknowledgementTaskId     String?              @db.Uuid
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy       User?         @relation("MetaAdsReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedBy     User?         @relation("MetaAdsReportPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  acknowledgedBy  User?         @relation("MetaAdsReportAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  acknowledgementTask Task?     @relation("MetaAdsReportAcknowledgementTask", fields: [acknowledgementTaskId], references: [id], onDelete: SetNull)

  @@index([clientProfileId, createdAt])
  @@index([clientProfileId, status, createdAt])
  @@index([clientProfileId, type, periodStart, periodEnd])
  @@index([clientVisible, status, createdAt])
  @@index([projectId])
  @@index([createdByUserId])
  @@index([publishedByUserId])
  @@index([acknowledgedByUserId])
  @@index([acknowledgementTaskId])
}

model ClientTikTokAdsConfig {
  id               String                    @id @default(uuid()) @db.Uuid
  clientProfileId  String                    @unique @db.Uuid
  advertiserId     String?
  businessCenterId String?
  pixelId          String?
  advertiserName   String?
  currency         String?
  timezone         String?
  connectionStatus TikTokAdsConnectionStatus @default(NOT_CONNECTED)
  lastSyncAt       DateTime?
  syncError        String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([connectionStatus])
  @@index([lastSyncAt])
}

model ClientTikTokAdsCredential {
  id              String    @id @default(uuid()) @db.Uuid
  clientProfileId String    @unique @db.Uuid
  accessTokenEnc  String?
  refreshTokenEnc String?
  tokenHash       String?
  tokenExpiresAt  DateTime?
  grantedScopes   String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([tokenExpiresAt])
}

model TikTokAdsDailyInsight {
  id                  String                @id @default(uuid()) @db.Uuid
  clientProfileId     String                @db.Uuid
  advertiserId        String
  date                DateTime
  level               TikTokAdsInsightLevel
  entityId            String
  entityName          String?
  spend               Decimal?              @db.Decimal(18, 6)
  impressions         Int?
  reach               Int?
  clicks              Int?
  ctr                 Decimal?              @db.Decimal(18, 6)
  cpc                 Decimal?              @db.Decimal(18, 6)
  cpm                 Decimal?              @db.Decimal(18, 6)
  videoViews          Int?
  videoViews2s        Int?
  videoViews6s        Int?
  videoCompletionRate Decimal?              @db.Decimal(18, 6)
  vtr                 Decimal?              @db.Decimal(18, 6)
  conversions         Int?
  costPerConversion   Decimal?              @db.Decimal(18, 6)
  conversionRate      Decimal?              @db.Decimal(18, 6)
  purchaseValue       Decimal?              @db.Decimal(18, 6)
  raw                 Json?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, date, level, entityId])
  @@index([clientProfileId, level, date])
  @@index([advertiserId, date])
}

model TikTokAdsSyncLog {
  id              String              @id @default(uuid()) @db.Uuid
  clientProfileId String              @db.Uuid
  advertiserId    String?
  status          TikTokAdsSyncStatus @default(RUNNING)
  trigger         String?
  startedAt       DateTime            @default(now())
  finishedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  recordsFetched  Int?
  apiCallCount    Int?
  createdAt       DateTime            @default(now())

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([clientProfileId, startedAt])
  @@index([status, startedAt])
  @@index([advertiserId])
}

model TikTokAdsReport {
  id                        String                 @id @default(uuid()) @db.Uuid
  clientProfileId           String                 @db.Uuid
  projectId                 String?                @db.Uuid
  periodStart               DateTime
  periodEnd                 DateTime
  type                      TikTokAdsReportType
  status                    TikTokAdsReportStatus  @default(DRAFT)
  summary                   String?
  metricsSnapshot           Json?
  createdByUserId           String?                @db.Uuid
  publishedByUserId         String?                @db.Uuid
  clientVisible             Boolean                @default(false)
  publishedAt               DateTime?
  acknowledgementRequestedAt DateTime?
  acknowledgedAt            DateTime?
  acknowledgedByUserId      String?                @db.Uuid
  acknowledgementTaskId     String?                @db.Uuid
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy       User?         @relation("TikTokAdsReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedBy     User?         @relation("TikTokAdsReportPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  acknowledgedBy  User?         @relation("TikTokAdsReportAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  acknowledgementTask Task?     @relation("TikTokAdsReportAcknowledgementTask", fields: [acknowledgementTaskId], references: [id], onDelete: SetNull)

  @@index([clientProfileId, createdAt])
  @@index([clientProfileId, status, createdAt])
  @@index([clientProfileId, type, periodStart, periodEnd])
  @@index([clientVisible, status, createdAt])
  @@index([projectId])
  @@index([createdByUserId])
  @@index([publishedByUserId])
  @@index([acknowledgedByUserId])
  @@index([acknowledgementTaskId])
}

model ClientPurchasedService {
  id              String                 @id @default(uuid()) @db.Uuid
  clientProfileId String                 @db.Uuid
  serviceKey      PurchasedServiceKey
  status          PurchasedServiceStatus @default(ACTIVE)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, serviceKey])
  @@index([clientProfileId, status])
  @@index([serviceKey, status])
}

model Project {
  id              String               @id @default(uuid()) @db.Uuid
  clientProfileId String               @db.Uuid
  serviceKey      PurchasedServiceKey?
  repositoryUrl   String?
  name            String
  slug            String
  description     String?
  figmaProjectUrl String?
  status          ProjectStatus        @default(PLANNED)
  priority        Priority             @default(MEDIUM)
  startDate       DateTime?
  dueDate         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  clientProfile    ClientProfile      @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  tasks            Task[]
  deliverySprints  DeliverySprint[]
  deliveryReleases DeliveryRelease[]
  repository       ProjectRepository?
  files            ProjectFile[]
  fileFolders      ProjectFileFolder[]
  metaAdsReports   MetaAdsReport[]
  tikTokAdsReports TikTokAdsReport[]
  workspaceSections WebAppWorkspaceSection[]
  workspaceMessages WebAppWorkspaceMessage[]
  workspaceRevisions WebAppWorkspaceRevision[]
  workspaceWeeklyReports WebAppWorkspaceWeeklyReport[]
  workspaceMeetingRequests WebAppWorkspaceMeetingRequest[]

  @@unique([clientProfileId, slug])
  @@index([clientProfileId])
  @@index([serviceKey])
  @@index([status])
  @@index([priority])
}

model Task {
  id                   String           @id @default(uuid()) @db.Uuid
  projectId            String           @db.Uuid
  sprintId             String?          @db.Uuid
  title                String
  description          String?
  status               TaskStatus       @default(TODO)
  priority             Priority         @default(MEDIUM)
  type                 TaskType         @default(FEATURE)
  workstream           TaskWorkstream   @default(FULLSTACK)
  severity             TaskSeverity?
  environment          TaskEnvironment?
  affectedUrl          String?
  reproductionSteps    String?
  reportedBy           String?
  code                 String?
  branchName           String?
  codePreparationNotes String?
  codePreparedAt       DateTime?
  codePreparedByUserId String?          @db.Uuid
  assigneeUserId       String?          @db.Uuid
  dueDate              DateTime?
  approvalRequired     Boolean          @default(false)
  approvalType         MetaAdsApprovalType?
  approvalStatus       MetaAdsApprovalStatus?
  approvalResponseNote String?
  approvalRequestedAt  DateTime?
  approvalRespondedAt  DateTime?
  approvalRespondedByUserId String?     @db.Uuid
  approvalContext      Json?
  referenceProjectFileId String?        @db.Uuid
  campaignRef          String?
  adSetRef             String?
  adRef                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint         DeliverySprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assignee       User?           @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  codePreparedBy User?           @relation("TaskCodePreparedBy", fields: [codePreparedByUserId], references: [id], onDelete: SetNull)
  approvalRespondedBy User?      @relation("TaskApprovalResponder", fields: [approvalRespondedByUserId], references: [id], onDelete: SetNull)
  referenceProjectFile ProjectFile? @relation("TaskReferenceProjectFile", fields: [referenceProjectFileId], references: [id], onDelete: SetNull)
  metaAdsReportAcknowledgements MetaAdsReport[] @relation("MetaAdsReportAcknowledgementTask")
  tikTokAdsReportAcknowledgements TikTokAdsReport[] @relation("TikTokAdsReportAcknowledgementTask")
  todos          TaskTodo[]
  workNotes      TaskWorkNote[]
  workspaceRevisions WebAppWorkspaceRevision[]

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeUserId])
  @@index([codePreparedByUserId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([workstream])
  @@index([severity])
  @@index([environment])
  @@index([approvalRequired])
  @@index([approvalType])
  @@index([approvalStatus])
  @@index([approvalRespondedByUserId])
  @@index([referenceProjectFileId])
  @@index([code])
  @@index([branchName])
}

