model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  role         UserRole
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@index([role])
  @@index([permissionId])
}

model User {
  id                   String      @id @default(uuid()) @db.Uuid
  email                String      @unique
  displayName          String?
  passwordHash         String
  accountType          AccountType
  role                 UserRole
  clientProfileId      String?     @db.Uuid
  status               UserStatus  @default(ACTIVE)
  sessionInvalidatedAt DateTime?
  lastLoginAt          DateTime?
  deletedAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  refreshTokens                     RefreshToken[]
  clientProfile                     ClientProfile?                      @relation(fields: [clientProfileId], references: [id], onDelete: SetNull)
  employeeClientAssignments         EmployeeClientAssignment[]          @relation("EmployeeClientAssignments")
  assignedTasks                     Task[]                              @relation("TaskAssignee")
  codePreparedTasks                 Task[]                              @relation("TaskCodePreparedBy")
  taskApprovalActions               Task[]                              @relation("TaskApprovalResponder")
  completedTaskTodos                TaskTodo[]                          @relation("TaskTodoCompletedBy")
  taskWorkNotes                     TaskWorkNote[]                      @relation("TaskWorkNoteAuthor")
  uploadedProjectFiles              ProjectFile[]                       @relation("ProjectFileUploadedBy")
  projectFileApprovalActions        ProjectFile[]                       @relation("ProjectFileApprovalResponder")
  createdProjectFileFolders         ProjectFileFolder[]                 @relation("ProjectFileFolderCreatedBy")
  assignedProjectFileFolders        ProjectFileFolderAssignment[]       @relation("ProjectFileFolderAssignedUser")
  projectFileShareLinks             ProjectFileShareLink[]              @relation("ProjectFileShareLinkCreatedBy")
  createdWorkspaceSections          WebAppWorkspaceSection[]            @relation("WorkspaceSectionCreatedBy")
  workspaceMessages                 WebAppWorkspaceMessage[]            @relation("WorkspaceMessageAuthor")
  requestedWorkspaceRevisions       WebAppWorkspaceRevision[]           @relation("WorkspaceRevisionRequestedBy")
  assignedWorkspaceRevisions        WebAppWorkspaceRevision[]           @relation("WorkspaceRevisionAssignedTo")
  workspaceRevisionTransitions      WebAppWorkspaceRevisionTransition[] @relation("WorkspaceRevisionTransitionActor")
  createdWeeklyReports              WebAppWorkspaceWeeklyReport[]       @relation("WorkspaceWeeklyReportAuthor")
  requestedMeetingRequests          WebAppWorkspaceMeetingRequest[]     @relation("WorkspaceMeetingRequestedBy")
  respondedMeetingRequests          WebAppWorkspaceMeetingRequest[]     @relation("WorkspaceMeetingRespondedBy")
  ownedCrmLeads                     CrmLead[]                           @relation("CrmLeadOwner")
  crmLeadActivities                 CrmLeadActivity[]                   @relation("CrmLeadActivityActor")
  releaseApprovalActions            DeliveryRelease[]                   @relation("DeliveryReleaseApprovalActor")
  triggeredCrmLeadScans             CrmLeadScanLog[]                    @relation("CrmLeadScanTriggeredBy")
  auditLogs                         AuditLog[]                          @relation("AuditActor")
  createdMetaAdsReports             MetaAdsReport[]                     @relation("MetaAdsReportCreatedBy")
  publishedMetaAdsReports           MetaAdsReport[]                     @relation("MetaAdsReportPublishedBy")
  acknowledgedMetaAdsReports        MetaAdsReport[]                     @relation("MetaAdsReportAcknowledgedBy")
  createdAmazonAdsReports           AmazonAdsReport[]                   @relation("AmazonAdsReportCreatedBy")
  publishedAmazonAdsReports         AmazonAdsReport[]                   @relation("AmazonAdsReportPublishedBy")
  acknowledgedAmazonAdsReports      AmazonAdsReport[]                   @relation("AmazonAdsReportAcknowledgedBy")
  createdTikTokAdsReports           TikTokAdsReport[]                   @relation("TikTokAdsReportCreatedBy")
  publishedTikTokAdsReports         TikTokAdsReport[]                   @relation("TikTokAdsReportPublishedBy")
  acknowledgedTikTokAdsReports      TikTokAdsReport[]                   @relation("TikTokAdsReportAcknowledgedBy")
  createdSocialMediaPosts           SocialMediaPost[]                   @relation("SocialMediaPostCreatedBy")
  assignedSocialMediaPosts          SocialMediaPost[]                   @relation("SocialMediaPostAssignedTo")
  createdSocialMediaReports         SocialMediaReport[]                 @relation("SocialMediaReportCreatedBy")
  publishedSocialMediaReports       SocialMediaReport[]                 @relation("SocialMediaReportPublishedBy")
  acknowledgedSocialMediaReports    SocialMediaReport[]                 @relation("SocialMediaReportAcknowledgedBy")
  ownedGrowthHubActions             GrowthHubAction[]                   @relation("GrowthHubActionOwner")
  createdGrowthHubActions           GrowthHubAction[]                   @relation("GrowthHubActionCreatedBy")
  createdGrowthHubWeeklyNotes       GrowthHubWeeklyNote[]               @relation("GrowthHubWeeklyNoteCreatedBy")
  createdGrowthHubReports           GrowthHubReport[]                   @relation("GrowthHubReportCreatedBy")
  publishedGrowthHubReports         GrowthHubReport[]                   @relation("GrowthHubReportPublishedBy")
  acknowledgedGrowthHubReports      GrowthHubReport[]                   @relation("GrowthHubReportAcknowledgedBy")
  createdGrowthHubRecommendations   GrowthHubRecommendation[]           @relation("GrowthHubRecommendationCreatedBy")
  convertedGrowthHubRecommendations GrowthHubRecommendation[]           @relation("GrowthHubRecommendationConvertedBy")
  createdInvoices                   ClientInvoice[]                     @relation("ClientInvoiceCreatedBy")
  createdClientTickets              ClientTicket[]                      @relation("ClientTicketCreatedBy")
  clientTicketMessages              ClientTicketMessage[]               @relation("ClientTicketMessageAuthor")

  @@index([accountType, role])
  @@index([accountType, status])
  @@index([clientProfileId])
  @@index([deletedAt])
  @@index([status])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt])
}

model ClientProfile {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique
  companyName  String
  contactEmail String?
  status       ClientStatus @default(ACTIVE)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users                     User[]
  employeeAssignments       EmployeeClientAssignment[]
  purchasedServices         ClientPurchasedService[]
  growthHubConfig           ClientGrowthHubConfig?
  growthHubActions          GrowthHubAction[]
  growthHubWeeklyNotes      GrowthHubWeeklyNote[]
  growthHubReports          GrowthHubReport[]
  growthHubRecommendations  GrowthHubRecommendation[]
  metaAdsConfig             ClientMetaAdsConfig?
  metaAdsCredential         ClientMetaAdsCredential?
  metaAdsInsights           MetaAdsDailyInsight[]
  metaAdsSyncLogs           MetaAdsSyncLog[]
  metaAdsReports            MetaAdsReport[]
  webMobileDesignConfig     ClientWebMobileDesignConfig?
  technicalSupportConfig    ClientTechnicalSupportConfig?
  seoAuditConfig            ClientSeoAuditConfig?
  socialMediaConfig         ClientSocialMediaConfig?
  socialMediaMetaCredential ClientSocialMediaMetaCredential?
  tikTokAdsConfig           ClientTikTokAdsConfig?
  tikTokAdsCredential       ClientTikTokAdsCredential?
  tikTokAdsInsights         TikTokAdsDailyInsight[]
  tikTokAdsSyncLogs         TikTokAdsSyncLog[]
  tikTokAdsReports          TikTokAdsReport[]
  amazonAdsConfig           ClientAmazonAdsConfig?
  amazonAdsCredential       ClientAmazonAdsCredential?
  amazonAdsInsights         AmazonAdsDailyInsight[]
  amazonAdsSyncLogs         AmazonAdsSyncLog[]
  amazonAdsReports          AmazonAdsReport[]
  socialMediaPosts          SocialMediaPost[]
  socialMediaPostInsights   SocialMediaPostInsight[]
  socialMediaReports        SocialMediaReport[]
  projects                  Project[]
  files                     ProjectFile[]
  invoices                  ClientInvoice[]
  tickets                   ClientTicket[]
  workspaceMeetingRequests  WebAppWorkspaceMeetingRequest[]
  convertedCrmLeads         CrmLead[]                        @relation("CrmLeadConvertedClient")

  @@index([status])
  @@index([deletedAt])
}

model ClientGrowthHubConfig {
  id              String          @id @default(uuid()) @db.Uuid
  clientProfileId String          @unique @db.Uuid
  primaryGoal     GrowthHubGoal?
  targetLeads     Int?
  targetRoas      Decimal?        @db.Decimal(18, 6)
  targetCpa       Decimal?        @db.Decimal(18, 6)
  targetRevenue   Decimal?        @db.Decimal(18, 6)
  reportingDay    String?
  notes           String?
  status          GrowthHubStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([primaryGoal])
  @@index([updatedAt])
}

model GrowthHubAction {
  id                String                  @id @default(uuid()) @db.Uuid
  clientProfileId   String                  @db.Uuid
  projectId         String?                 @db.Uuid
  title             String
  description       String?
  ownerUserId       String?                 @db.Uuid
  status            GrowthHubActionStatus   @default(TODO)
  priority          GrowthHubActionPriority @default(MEDIUM)
  dueAt             DateTime?
  clientVisible     Boolean                 @default(false)
  relatedEntityType String?
  relatedEntityId   String?
  createdByUserId   String?                 @db.Uuid
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner         User?         @relation("GrowthHubActionOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("GrowthHubActionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clientProfileId, status, priority])
  @@index([clientProfileId, clientVisible])
  @@index([projectId])
  @@index([ownerUserId])
  @@index([createdByUserId])
  @@index([dueAt])
  @@index([updatedAt])
}

model GrowthHubWeeklyNote {
  id              String   @id @default(uuid()) @db.Uuid
  clientProfileId String   @db.Uuid
  projectId       String?  @db.Uuid
  weekStart       DateTime
  weekEnd         DateTime
  summary         String
  nextFocus       String?
  risks           Json?
  clientVisible   Boolean  @default(false)
  createdByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("GrowthHubWeeklyNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clientProfileId, weekStart])
  @@index([clientProfileId, clientVisible])
  @@index([projectId])
  @@index([createdByUserId])
  @@index([updatedAt])
}

model GrowthHubReport {
  id                         String                @id @default(uuid()) @db.Uuid
  clientProfileId            String                @db.Uuid
  projectId                  String?               @db.Uuid
  periodStart                DateTime
  periodEnd                  DateTime
  type                       GrowthHubReportType
  status                     GrowthHubReportStatus @default(DRAFT)
  summary                    String?
  metricsSnapshot            Json?
  createdByUserId            String?               @db.Uuid
  publishedByUserId          String?               @db.Uuid
  clientVisible              Boolean               @default(false)
  publishedAt                DateTime?
  acknowledgementRequestedAt DateTime?
  acknowledgedAt             DateTime?
  acknowledgedByUserId       String?               @db.Uuid
  acknowledgementTaskId      String?               @db.Uuid
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  clientProfile       ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  project             Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy           User?         @relation("GrowthHubReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedBy         User?         @relation("GrowthHubReportPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  acknowledgedBy      User?         @relation("GrowthHubReportAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  acknowledgementTask Task?         @relation("GrowthHubReportAcknowledgementTask", fields: [acknowledgementTaskId], references: [id], onDelete: SetNull)

  @@index([clientProfileId, createdAt])
  @@index([clientProfileId, status, createdAt])
  @@index([clientProfileId, type, periodStart, periodEnd])
  @@index([clientVisible, status, createdAt])
  @@index([projectId])
  @@index([createdByUserId])
  @@index([publishedByUserId])
  @@index([acknowledgedByUserId])
  @@index([acknowledgementTaskId])
}

model ClientMetaAdsConfig {
  id                 String                  @id @default(uuid()) @db.Uuid
  clientProfileId    String                  @unique @db.Uuid
  businessId         String?
  adAccountId        String?
  pixelId            String?
  instagramAccountId String?
  facebookPageId     String?
  currency           String?
  timezone           String?
  connectionStatus   MetaAdsConnectionStatus @default(NOT_CONNECTED)
  lastSyncAt         DateTime?
  syncError          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([connectionStatus])
  @@index([lastSyncAt])
}

model ClientMetaAdsCredential {
  id              String    @id @default(uuid()) @db.Uuid
  clientProfileId String    @unique @db.Uuid
  accessTokenEnc  String?
  tokenHash       String?
  tokenExpiresAt  DateTime?
  grantedScopes   String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([tokenExpiresAt])
}

model ClientSocialMediaConfig {
  id                         String                      @id @default(uuid()) @db.Uuid
  clientProfileId            String                      @unique @db.Uuid
  activePlatforms            SocialMediaPlatform[]       @default([])
  instagramUsername          String?
  instagramAccountId         String?
  facebookPageId             String?
  tiktokUsername             String?
  linkedinPageUrl            String?
  contentFrequency           String?
  primaryGoal                SocialMediaGoal?
  toneOfVoice                String?
  hashtags                   String[]                    @default([])
  instagramProfilePictureUrl String?
  facebookProfilePictureUrl  String?
  facebookPageName           String?
  igFollowerCount            Int?
  igImpressions              Int?
